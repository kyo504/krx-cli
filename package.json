{
  "name": "krx-cli",
  "version": "1.7.3",
  "description": "CLI & MCP server for KRX (Korea Exchange) Open API — query Korean stock market data (KOSPI, KOSDAQ, ETF, bonds, derivatives) from terminal or AI agents",
  "type": "module",
  "bin": {
    "krx": "./dist/cli.js",
    "krx-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test:e2e": "vitest run --config tests/vitest.config.e2e.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "keywords": [
    "krx",
    "korea-exchange",
    "kospi",
    "kosdaq",
    "korean-stock-market",
    "stock",
    "finance",
    "market-data",
    "cli",
    "mcp",
    "mcp-server",
    "agent",
    "ai",
    "etf",
    "bond",
    "derivative",
    "한국거래소",
    "주식",
    "시세"
  ],
  "author": "Daniel Jung",
  "license": "MIT",
  "homepage": "https://github.com/kyo504/krx-cli#readme",
  "bugs": {
    "url": "https://github.com/kyo504/krx-cli/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kyo504"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyo504/krx-cli.git"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^25.4.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "git": {
      "requireUpstream": false,
      "requireCleanWorkingDir": false,
      "tagName": "v${version}",
      "commitMessage": "chore(release): v${version}"
    },
    "github": {
      "release": true
    },
    "hooks": {
      "after:bump": "sed -i '' \"s/  version: \\\".*\\\"/  version: \\\"${version}\\\"/\" SKILL.md && git add SKILL.md"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md",
        "header": "# Changelog",
        "writerOpts": {
          "types": [
            {
              "type": "feat",
              "section": "New Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "refactor",
              "section": "Refactoring"
            },
            {
              "type": "perf",
              "section": "Performance"
            },
            {
              "type": "build",
              "section": "Build System"
            },
            {
              "type": "ci",
              "section": "Build System"
            },
            {
              "type": "docs",
              "section": "Documentation"
            },
            {
              "type": "test",
              "section": "Tests"
            },
            {
              "type": "revert",
              "section": "Miscellaneous"
            },
            {
              "type": "chore",
              "section": "Miscellaneous"
            }
          ]
        }
      }
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
